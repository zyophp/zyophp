<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirecionar tudo para o front controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Bloquear acesso a arquivos ocultos
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
